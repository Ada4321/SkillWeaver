# Copy to `.env` (or source it) and fill in before running anything under scripts/.

# Root of the downloaded SkillWeaver data bundle (scenes / assets / ckpts / misc).
# Everything data-side in the repo derives from this one variable.
export SKILLWEAVER_DATA_ROOT="your_path_to_skillweaver_root"

# Gemini API key used by the VLM actor/judge (skills/gemini.py).
export GEMINI_API_KEY="your_gemini_api_key"
